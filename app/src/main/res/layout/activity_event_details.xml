<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/txtDetailName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Esemény neve"
            android:textColor="@color/white"
            android:textSize="30sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/txtDetailCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Konferencia"
            android:textColor="@color/accent"
            android:textSize="15sp"
            android:layout_marginTop="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_background"
            android:orientation="vertical"
            android:padding="18dp"
            android:layout_marginTop="24dp">

            <TextView
                android:id="@+id/txtDetailDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Dátum"
                android:textColor="@color/white"
                android:textSize="17sp"/>

            <TextView
                android:id="@+id/txtDetailLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Helyszín"
                android:textColor="@color/gray"
                android:textSize="15sp"
                android:layout_marginTop="8dp"/>

            <TextView
                android:id="@+id/txtDetailStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Aktív"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:background="@drawable/button_background"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:layout_marginTop="14dp"/>

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Leírás"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginTop="26dp"/>

        <TextView
            android:id="@+id/txtDetailDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Leírás szövege"
            android:textColor="@color/gray"
            android:textSize="15sp"
            android:lineSpacingExtra="4dp"
            android:layout_marginTop="10dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Szervezési modulok"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginTop="30dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="14dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:background="@drawable/card_background"
                android:gravity="center_vertical"
                android:paddingLeft="18dp"
                android:text="👥 Résztvevőkezelés és jogosultságok"
                android:textColor="@color/white"
                android:textSize="17sp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:background="@drawable/card_background"
                android:gravity="center_vertical"
                android:paddingLeft="18dp"
                android:text="🎫 QR alapú beléptetés"
                android:textColor="@color/white"
                android:textSize="17sp"
                android:layout_marginTop="12dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:background="@drawable/card_background"
                android:gravity="center_vertical"
                android:paddingLeft="18dp"
                android:text="🧩 Konferencia szekciók"
                android:textColor="@color/white"
                android:textSize="17sp"
                android:layout_marginTop="12dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:background="@drawable/card_background"
                android:gravity="center_vertical"
                android:paddingLeft="18dp"
                android:text="🗺️ Térkép és hasznos információk"
                android:textColor="@color/white"
                android:textSize="17sp"
                android:layout_marginTop="12dp"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>